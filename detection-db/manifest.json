{
  "name": "CodeInspectus Detection Database",
  "version": "0.2.0",
  "date": "2026-07-04",
  "description": "CodeInspectus's curated detections (the moat, §9): AI-code / vibe-coding / framework-specific failure modes the generic engines miss. Grows via human-reviewed weekly intake. Generic SAST is intentionally NOT here — that is the engines' job.",
  "engine_versions": {
    "opengrep": "1.23.0",
    "gitleaks": "8.30.1",
    "trivy": "0.71.2"
  },
  "opengrep_rulesets": [
    {
      "name": "security-baseline",
      "source": "codeinspectus-mit",
      "license": "MIT",
      "note": "CodeInspectus's ORIGINAL MIT-licensed Opengrep security ruleset (see detection-db/opengrep-rules/security-baseline/LICENSE-PROVENANCE.md). Not derived from the Commons-Clause opengrep-rules or the Semgrep-Rules-License semgrep-rules corpora, so it is clean to bundle and sell. Narrower than the full upstream registry; coverage grows via weekly intake. Pre-launch: legal review of rule provenance."
    }
  ],
  "custom_rules": [
    {
      "id": "ci-ai-client-hardcoded-secret",
      "engine": "codeinspectus-ai",
      "name": "Hard-coded secret in client-reachable code",
      "kind": "ai",
      "cwe": ["CWE-798", "CWE-312"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-secret-in-bundle",
      "engine": "codeinspectus-ai",
      "name": "Secret compiled into shipped bundle",
      "kind": "ai",
      "cwe": ["CWE-798", "CWE-312"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-public-env-secret",
      "engine": "codeinspectus-ai",
      "name": "Secret exposed via client-visible env prefix",
      "kind": "ai",
      "cwe": ["CWE-798", "CWE-312"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-supabase-service-role-client",
      "engine": "codeinspectus-ai",
      "name": "Supabase service_role key in client-reachable code",
      "kind": "ai",
      "cwe": ["CWE-798", "CWE-285"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-llm-key-browser-exposed",
      "engine": "codeinspectus-ai",
      "name": "LLM SDK client allows browser use (dangerouslyAllowBrowser: true)",
      "kind": "ai",
      "cwe": ["CWE-798", "CWE-312"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-rls-using-true",
      "engine": "codeinspectus-ai",
      "name": "RLS policy uses USING (true) — table fully open",
      "kind": "ai",
      "cwe": ["CWE-863", "CWE-285"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-rls-missing",
      "engine": "codeinspectus-ai",
      "name": "Public table created without Row Level Security",
      "kind": "ai",
      "cwe": ["CWE-862", "CWE-285"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-rls-inverted-auth",
      "engine": "codeinspectus-ai",
      "name": "RLS policy tests aud/role instead of user identity",
      "kind": "ai",
      "cwe": ["CWE-863"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-edge-fn-no-auth",
      "engine": "codeinspectus-ai",
      "name": "Supabase Edge Function with no auth verification",
      "kind": "ai",
      "cwe": ["CWE-862"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-storage-rls-public",
      "engine": "codeinspectus-ai",
      "name": "Permissive RLS policy on storage.objects (public bucket files)",
      "kind": "ai",
      "cwe": ["CWE-863", "CWE-285"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-prompt-injection-sink",
      "engine": "codeinspectus-ai",
      "name": "Potential prompt-injection sink",
      "kind": "ai",
      "cwe": ["CWE-1426"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-client-metadata-authz",
      "engine": "codeinspectus-ai",
      "name": "Authorization decision trusts client-writable user_metadata",
      "kind": "ai",
      "cwe": ["CWE-639", "CWE-284", "CWE-863"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-ai-llm-output-dangerous-html",
      "engine": "codeinspectus-ai",
      "name": "Untrusted or model output rendered as raw HTML (React __html sink)",
      "kind": "ai",
      "cwe": ["CWE-79", "CWE-116"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-sql-injection-string-build",
      "engine": "opengrep",
      "name": "SQL injection via string-built query (JS/TS)",
      "kind": "sast",
      "cwe": ["CWE-89"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-sql-injection-python",
      "engine": "opengrep",
      "name": "SQL injection via string-built query (Python)",
      "kind": "sast",
      "cwe": ["CWE-89"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-command-injection",
      "engine": "opengrep",
      "name": "Command injection via shell string (JS/TS)",
      "kind": "sast",
      "cwe": ["CWE-77"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-command-injection-python",
      "engine": "opengrep",
      "name": "Command injection via shell=True (Python)",
      "kind": "sast",
      "cwe": ["CWE-77"],
      "source": "codeinspectus-custom"
