      "name": "JWT verification accepts alg 'none'",
      "kind": "sast",
      "cwe": ["CWE-347"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-cors-wildcard-credentials",
      "engine": "opengrep",
      "name": "CORS wildcard origin with credentials",
      "kind": "sast",
      "cwe": ["CWE-942"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-insecure-cookie",
