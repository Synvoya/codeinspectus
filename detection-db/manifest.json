      "cwe": ["CWE-94"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-eval-python",
      "engine": "opengrep",
      "name": "Dynamic eval/exec of non-literal (Python)",
      "kind": "sast",
      "cwe": ["CWE-94"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-nosql-injection",
      "engine": "opengrep",
      "name": "NoSQL injection from request data",
      "kind": "sast",
      "cwe": ["CWE-943"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-path-traversal",
      "engine": "opengrep",
      "name": "Path traversal from request input",
      "kind": "sast",
      "cwe": ["CWE-22"],
      "source": "codeinspectus-custom"
    },
    {
      "id": "ci-baseline-dom-xss-innerhtml",
